{
  "version": 2,
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "buildCommand": "mkdir -p public/asset && cp -r asset/* public/asset/",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
