{
  "version": 2,
  "buildCommand": "mkdir -p public/asset && cp -r asset/* public/asset/",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/install.php", "destination": "/api/install.php" },
    { "source": "/(.*)", "destination": "/api/index.php" }
  ]
}
