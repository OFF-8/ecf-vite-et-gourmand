{
  "version": 2,
  "buildCommand": "mkdir -p public/asset && cp -r asset/* public/asset/",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/install.php", "dest": "/api/install.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
